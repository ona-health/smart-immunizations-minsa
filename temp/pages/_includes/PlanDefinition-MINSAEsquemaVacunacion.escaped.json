            &lt;th scope=\&quot;row\&quot;&gt;&lt;b&gt;Jurisdiction: &lt;/b&gt;&lt;/th&gt;\n            &lt;td style=\&quot;padding-left: 4px;\&quot;&gt;PE&lt;/td&gt;\n        &lt;/tr&gt;\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n        &lt;tr&gt;\n            &lt;th scope=\&quot;row\&quot;&gt;&lt;b&gt;Related Artifacts: &lt;/b&gt;&lt;/th&gt;\n            &lt;td style=\&quot;padding-left: 4px;\&quot;&gt;\n                \n                \n                &lt;p&gt;&lt;b&gt;References&lt;/b&gt;&lt;/p&gt;\n                &lt;ul&gt;\n                    \n                    &lt;li&gt;&lt;div&gt;&lt;p&gt;NTS N 196-MINSA/DGIESP-2022: Norma Tecnica de Salud que establece el Esquema Nacional de Vacunacion&lt;/p&gt;\n&lt;/div&gt;&lt;br/&gt;&lt;a href=\&quot;null\&quot;/&gt;&lt;/li&gt;\n                    \n                &lt;/ul&gt;\n                \n                \n                \n                \n                \n                \n            &lt;/td&gt;\n        &lt;/tr&gt;\n        \n\n        \n\n        \n        &lt;tr&gt;\n            &lt;th scope=\&quot;row\&quot;&gt;&lt;b&gt;Actions: &lt;/b&gt;&lt;/th&gt;\n            &lt;td style=\&quot;padding-left: 4px;\&quot;&gt;\n                &lt;table class=\&quot;grid-dict\&quot;&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion BCG:&lt;/b&gt; Administrar vacuna BCG al recien nacido.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente es recien nacido y no tiene registro de vacunacion BCG\n                            \n                            &lt;i&gt;(Paciente necesita vacuna BCG)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSABCGVacunacion.html\&quot;&gt;MINSA - Vacunacion BCG&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion Hepatitis B - Dosis de nacimiento:&lt;/b&gt; Administrar vacuna contra Hepatitis B al recien nacido dentro de las primeras 24 horas de vida.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente es recien nacido y no tiene registro de dosis de nacimiento de Hepatitis B\n                            \n                            &lt;i&gt;(Paciente necesita dosis de nacimiento de Hepatitis B)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion Pentavalente (DPT-HepB-Hib):&lt;/b&gt; Administrar vacuna Pentavalente a los 2, 4 y 6 meses de edad.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita dosis de vacuna Pentavalente\n                            \n                            &lt;i&gt;(Paciente necesita vacuna Pentavalente)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSAPentavalenteVacunacion.html\&quot;&gt;MINSA - Vacunacion Pentavalente (DPT-HepB-Hib)&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion contra Poliomielitis (IPV/APO):&lt;/b&gt; Administrar vacunas contra Poliomielitis: IPV a los 2 y 4 meses, APO a los 6 y 18 meses, refuerzo APO a los 4 anos.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita dosis de vacuna contra Poliomielitis\n                            \n                            &lt;i&gt;(Paciente necesita vacuna Polio)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSAPolioVacunacion.html\&quot;&gt;MINSA - Vacunacion contra Poliomielitis (IPV/APO)&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion contra Rotavirus:&lt;/b&gt; Administrar vacuna contra Rotavirus a los 2 y 4 meses de edad.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita dosis de vacuna contra Rotavirus\n                            \n                            &lt;i&gt;(Paciente necesita vacuna Rotavirus)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSARotavirusVacunacion.html\&quot;&gt;MINSA - Vacunacion contra Rotavirus&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion contra Neumococo:&lt;/b&gt; Administrar vacuna antineumococica conjugada a los 2 y 4 meses, con refuerzo a los 12 meses de edad.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita dosis de vacuna contra Neumococo\n                            \n                            &lt;i&gt;(Paciente necesita vacuna Neumococo)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSANeumococoVacunacion.html\&quot;&gt;MINSA - Vacunacion contra Neumococo (PCV)&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion contra Influenza:&lt;/b&gt; Administrar vacuna contra Influenza: primera dosis a los 7 meses, segunda dosis a los 8 meses, luego dosis anual hasta los 5 anos.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita dosis de vacuna contra Influenza\n                            \n                            &lt;i&gt;(Paciente necesita vacuna Influenza)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion SPR (Sarampion-Paperas-Rubeola):&lt;/b&gt; Administrar vacuna SPR a los 12 meses con refuerzo a los 18 meses de edad.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita dosis de vacuna SPR\n                            \n                            &lt;i&gt;(Paciente necesita vacuna SPR)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSASPRVacunacion.html\&quot;&gt;MINSA - Vacunacion SPR (Sarampion-Paperas-Rubeola)&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion Antiamarilica (Fiebre Amarilla):&lt;/b&gt; Administrar vacuna contra Fiebre Amarilla a los 15 meses de edad.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita vacuna contra Fiebre Amarilla\n                            \n                            &lt;i&gt;(Paciente necesita vacuna Antiamarilica)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion DPT - Refuerzos:&lt;/b&gt; Administrar refuerzos de DPT a los 18 meses y 4 anos de edad.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            El paciente necesita refuerzo de DPT\n                            \n                            &lt;i&gt;(Paciente necesita refuerzo DPT)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                    &lt;tr&gt;\n                        &lt;td&gt;\n                            \n                            &lt;b&gt; Vacunacion contra VPH (Virus del Papiloma Humano):&lt;/b&gt; Administrar vacuna contra VPH a ninas de 9 a 13 anos, esquema de 2 dosis con intervalo de 6 meses.\n                            \n                            &lt;br/&gt;\n                            \n                            \n                            &lt;b&gt;If:&lt;/b&gt;\n                            \n                            &lt;i&gt;Applicability:&lt;/i&gt;\n                            \n                            La paciente es nina de 9 a 13 anos y necesita vacuna VPH\n                            \n                            &lt;i&gt;(Paciente necesita vacuna VPH)&lt;/i&gt;\n                            &lt;br/&gt;\n                            \n                            \n                            \n                            \n                            &lt;b&gt;Then:&lt;/b&gt; &lt;i&gt;Definition:&lt;/i&gt; &lt;a href=\&quot;PlanDefinition-MINSAHPVVacunacion.html\&quot;&gt;MINSA - Vacunacion contra VPH (Virus del Papiloma Humano)&lt;/a&gt;&lt;br/&gt;\n                            \n                            \n                            \n                        &lt;/td&gt;\n                    &lt;/tr&gt;\n                    \n                &lt;/table&gt;\n            &lt;/td&gt;\n        &lt;/tr&gt;\n        \n    &lt;/table&gt;\n&lt;/div&gt;\n&lt;/div&gt;&quot;},&quot;extension&quot;:[{&quot;url&quot;:&quot;http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-knowledgeCapability&quot;,&quot;valueCode&quot;:&quot;computable&quot;}],&quot;url&quot;:&quot;http://minsa.gob.pe/immunizations/PlanDefinition/MINSAEsquemaVacunacion&quot;,&quot;version&quot;:&quot;1.0.0&quot;,&quot;name&quot;:&quot;MINSAEsquemaVacunacion&quot;,&quot;title&quot;:&quot;Esquema Nacional de Vacunacion - MINSA Peru&quot;,&quot;type&quot;:{&quot;coding&quot;:[{&quot;system&quot;:&quot;http://terminology.hl7.org/CodeSystem/plan-definition-type&quot;,&quot;code&quot;:&quot;eca-rule&quot;}]},&quot;status&quot;:&quot;active&quot;,&quot;experimental&quot;:false,&quot;date&quot;:&quot;2026-03-16T12:33:41-04:00&quot;,&quot;publisher&quot;:&quot;MINSA - Ministerio de Salud del Perú&quot;,&quot;contact&quot;:[{&quot;name&quot;:&quot;MINSA - Ministerio de Salud del Perú&quot;,&quot;telecom&quot;:[{&quot;system&quot;:&quot;url&quot;,&quot;value&quo