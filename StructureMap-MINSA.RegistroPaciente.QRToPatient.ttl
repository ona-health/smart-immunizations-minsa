t; </b></span>ext.value = <span style=\"color: maroon\">coding</span> <i>\"SetDistValue\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"CreateDistExt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"DistAnswer\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"Distrito\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"PatientAddress\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">Extrae el recurso RelatedPerson (cuidador) del cuestionario</span>#xD;\n<b>group </b>ExtractCuidador<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>QResp, <b>target</b> <span style=\"color: maroon\">caregiver</span><span style=\"color: navy\"> : </span>RelatedPerson, <b>source</b> <span style=\"color: maroon\">patient</span><span style=\"color: navy\"> : </span>Patient<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  src<span style=\"color: navy\"><b> -&gt; </b></span> caregiver.id = <b>uuid</b><span style=\"color: navy\">(</span><span style=\"color: navy\">)</span><span style=\"color: navy\">, </span> caregiver.active = <span style=\"color: blue\">true</span><span style=\"color: navy\">, </span> caregiver.patient = <b>reference</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">patient</span><span style=\"color: navy\">)</span> <i>\"CaregiverStatic\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">DNI del cuidador</span>#xD;\n  src.item<b> as </b><span style=\"color: maroon\">item</span><b> where </b>linkId = 'caregiver-dni'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    item.answer first<b> as </b><span style=\"color: maroon\">answer</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      answer.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>caregiver.identifier = <b>create</b><span style=\"color: navy\">(</span><span style=\"color: blue\">'Identifier'</span><span style=\"color: navy\">)</span><b> as </b><span style=\"color: maroon\">id</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val<span style=\"color: navy\"><b> -&gt; </b></span> id.use = <span style=\"color: blue\">'official'</span><span style=\"color: navy\">, </span> id.system = <span style=\"color: blue\">'http://minsa.gob.pe/sid/dni'</span><span style=\"color: navy\">, </span> id.value = <span style=\"color: maroon\">val</span> <i>\"SetCaregiverDNIValues\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"CreateCaregiverDNI\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"CaregiverDNIAnswer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"CaregiverDNI\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Nombre del cuidador</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>caregiver.name = <b>create</b><span style=\"color: navy\">(</span><span style=\"color: blue\">'HumanName'</span><span style=\"color: navy\">)</span><b> as </b><span style=\"color: maroon\">name</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src<span style=\"color: navy\"><b> -&gt; </b></span>name.use = <span style=\"color: blue\">'official'</span> <i>\"CaregiverNameUse\"</i><span style=\"color: navy\">;</span>#xD;\n    src.item<b> as </b><span style=\"color: maroon\">item</span><b> where </b>linkId = 'caregiver-given-name'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      item.answer first<b> as </b><span style=\"color: maroon\">answer</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        answer.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>name.given = <span style=\"color: maroon\">val</span> <i>\"SetCaregiverGivenName\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"CaregiverGivenAnswer\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"CaregiverGivenName\"</i><span style=\"color: navy\">;</span>#xD;\n    src.item<b> as </b><span style=\"color: maroon\">item</span><b> where </b>linkId = 'caregiver-paternal-surname'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      item.answer first<b> as </b><span style=\"color: maroon\">answer</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        answer.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>name.family = <span style=\"color: maroon\">val</span> <i>\"SetCaregiverFamilyName\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"CaregiverFamilyAnswer\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"CaregiverFamilyName\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"CaregiverName\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Telefono del cuidador</span>#xD;\n  src.item<b> as </b><span style=\"color: maroon\">item</span><b> where </b>linkId = 'caregiver-phone'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    item.answer first<b> as </b><span style=\"color: maroon\">answer</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      answer.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>caregiver.telecom = <b>create</b><span style=\"color: navy\">(</span><span style=\"color: blue\">'ContactPoint'</span><span style=\"color: navy\">)</span><b> as </b><span style=\"color: maroon\">phone</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val<span style=\"color: navy\"><b> -&gt; </b></span> phone.system = <span style=\"color: blue\">'phone'</span><span style=\"color: navy\">, </span> phone.use = <span style=\"color: blue\">'mobile'</span><span style=\"color: navy\">, </span> phone.value = <span style=\"color: maroon\">val</span> <i>\"SetPhoneValues\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"CreatePhone\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"PhoneAnswer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"CaregiverPhone\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Relacion de parentesco</span>#xD;\n  src.item<b> as </b><span style=\"color: maroon\">item</span><b> where </b>linkId = 'caregiver-relationship'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    item.answer first<b> as </b><span style=\"color: maroon\">answer</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      answer.value<b> as </b><span style=\"color: maroon\">coding</span><span style=\"color: navy\"><b> -&gt; </b></span>caregiver.relationship = <b>create</b><span style=\"color: navy\">(</span><span style=\"color: blue\">'CodeableConcept'</span><span style=\"color: navy\">)</span><b> as </b><span style=\"color: maroon\">cc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        coding<span style=\"color: navy\"><b> -&gt; </b></span>cc.coding = <span style=\"color: maroon\">coding</span> <i>\"SetRelCoding\"</i><span style=\"color: navy\">;</span>#xD;\n        coding.display<b> as </b><span style=\"color: maroon\">display</span><span style=\"color: navy\"><b> -&gt; </b></span>cc.text = <span style=\"color: maroon\">display</span> <i>\"SetRelText\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"CreateRelCC\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"RelAnswer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"CaregiverRelationship\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">Crea un Group que vincula al cuidador con el paciente</span>#xD;\n<b>group </b>ExtractGroup<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>QResp, <b>target</b> <span style=\"color: maroon\">group</span><span style=\"color: navy\"> : </span>Group, <b>source</b> <span style=\"color: maroon\">patient</span><span style=\"color: navy\"> : </span>Patient, <b>source</b> <span style=\"color: maroon\">caregiver</span><span style=\"color: navy\"> : </span>RelatedPerson<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  src<span style=\"color: navy\"><b> -&gt; </b></span> group.id = <b>uuid</b><span style=\"color: navy\">(</span><span style=\"color: navy\">)</span><span style=\"color: navy\">, </span> group.type = <span style=\"color: blue\">'person'</span><span style=\"color: navy\">, </span> group.actual = <span style=\"color: blue\">true</span><span style=\"color: navy\">, </span> group.active = <span style=\"color: blue\">true</span> <i>\"GroupStatic\"</i><span style=\"color: navy\">;</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>group.name = <span style=\"color: blue\">'Familia'</span> <i>\"GroupName\"</i><span style=\"color: navy\">;</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>group.member = <b>create</b><span style=\"color: navy\">(</span><span style=\"color: blue\">'Group_Member'</span><span style=\"color: navy\">)</span><b> as </b><span style=\"color: maroon\">memberPatient</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    patient<span style=\"color: navy\"><b> -&gt; </b></span>memberPatient.entity = <b>reference</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">patient</span><span style=\"color: navy\">)</span> <i>\"SetPatientMember\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"PatientMember\"</i><span style=\"color: navy\">;</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>group.member = <b>create</b><span style=\"color: navy\">(</span><span style=\"color: blue\">'Group_Member'</span><span style=\"color: navy\">)</span><b> as </b><span style=\"color: maroon\">memberCaregiver</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    caregiver<span style=\"color: navy\"><b> -&gt; </b></span>memberCaregiver.entity = <b>reference</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">caregiver</span><span style=\"color: navy\">)</span> <i>\"SetCaregiverMember\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"CaregiverMember\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
