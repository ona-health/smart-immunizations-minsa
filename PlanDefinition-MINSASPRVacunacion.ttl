  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "La vacuna SPR (triple virica) protege contra sarampion, paperas y\n      rubeola. La primera dosis se administra a los 12 meses de edad, cuando los anticuerpos\n      maternos han disminuido suficientemente para permitir una respuesta inmune adecuada."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 1ra dosis de SPR" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 12 meses cumple las condiciones para recibir la primera\n    dosis de vacuna SPR segun el protocolo nacional de inmunizaciones." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 12 meses o mas y no ha recibido la 1ra dosis de SPR" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 1ra dosis de SPR" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "La dosis de refuerzo de SPR a los 18 meses asegura la proteccion a\n      largo plazo. Aproximadamente el 5% de los ninos no responden a la primera dosis,\n      por lo que la segunda dosis garantiza la inmunidad de la poblacion."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la dosis de refuerzo de SPR" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 18 meses cumple las condiciones para recibir la dosis\n    de refuerzo de vacuna SPR segun el protocolo nacional de inmunizaciones." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 18 meses o mas, ha recibido la 1ra dosis y no ha recibido el refuerzo de SPR" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita refuerzo de SPR" ]
       ]
     ] ) ;
