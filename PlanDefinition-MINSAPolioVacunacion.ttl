  fhir:description [ fhir:v "Logica de decision para la vacunacion contra Poliomielitis segun el Esquema Nacional de Vacunacion\ndel Peru. Esquema secuencial: IPV (inyectable) a los 2 y 4 meses, APO (oral) a los 6 y 18 meses,\ny refuerzo con APO a los 4 anos de edad."] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [
