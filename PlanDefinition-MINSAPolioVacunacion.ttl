       ] ;
       fhir:code [ fhir:v "PE" ] ;
       fhir:display [ fhir:v "Peru" ]
     ] )
  ] ) ; # 
  fhir:relatedArtifact ( [
     fhir:type [ fhir:v "citation" ] ;
     fhir:citation [ fhir:v "NTS N 196-MINSA/DGIESP-2022: Norma Tecnica de Salud que establece el Esquema Nacional de Vacunacion" ]
  ] [
     fhir:type [ fhir:v "depends-on" ] ;
     fhir:display [ fhir:v "WHO SMART Guidelines - Polio bOPV plus IPV Decision Table" ] ;
     fhir:resource [
       fhir:v "http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTPolioBOPVPlusIPV"^^xsd:anyURI ;
       fhir:l <http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTPolioBOPVPlusIPV>
     ]
  ] ) ; # 
  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Peru utiliza un esquema secuencial de vacunacion contra Poliomielitis.\n      Las dos primeras dosis se administran con vacuna inactivada (IPV) por via intramuscular\n      para minimizar el riesgo de poliomielitis asociada a la vacuna."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 1ra dosis de IPV" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 2 meses cumple las condiciones para recibir la primera\n    dosis de vacuna IPV (inactivada) contra Poliomielitis." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 2 meses o mas y no ha recibido la 1ra dosis de IPV" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 1ra dosis de IPV" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Segunda dosis de IPV a los 4 meses. Con esta dosis se completa la serie\n      de vacuna inactivada antes de continuar con APO oral."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 2da dosis de IPV" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 4 meses cumple las condiciones para recibir la segunda\n    dosis de vacuna IPV (inactivada) contra Poliomielitis." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 4 meses o mas, ha recibido la 1ra dosis de IPV y no ha recibido la 2da dosis" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 2da dosis de IPV" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "A partir de la tercera dosis se utiliza la vacuna oral (APO/bOPV)\n      que contribuye a la inmunidad de mucosas y a la proteccion comunitaria."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 3ra dosis de Polio (APO)" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 6 meses cumple las condiciones para recibir la tercera\n    dosis de vacuna contra Poliomielitis (APO oral)." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 6 meses o mas, ha recibido 2 dosis de IPV y no ha recibido la 3ra dosis (APO)" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 3ra dosis de Polio APO" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Primer refuerzo con APO oral a los 18 meses de edad para\n      fortalecer la inmunidad contra Poliomielitis."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita el 1er refuerzo de Polio (APO)" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 18 meses cumple las condiciones para recibir el primer\n    refuerzo de vacuna APO contra Poliomielitis." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 18 meses o mas, ha completado la serie primaria y no ha recibido el 1er refuerzo" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 1er refuerzo de Polio APO" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Segundo refuerzo con APO oral a los 4 anos de edad, completando\n      el esquema de vacunacion contra Poliomielitis."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita el 2do refuerzo de Polio (APO)" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 4 anos cumple las condiciones para recibir el segundo\n    refuerzo de vacuna APO contra Poliomielitis." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 4 anos o mas, ha recibido el 1er refuerzo y no ha recibido el 2do refuerzo" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 2do refuerzo de Polio APO" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] ) . # 

