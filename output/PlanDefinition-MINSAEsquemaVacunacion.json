  "text" : {
    "status" : "extensions",
    "div" : "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n<div>\n    <table class=\"grid dict\">\n        \n        <tr>\n            <th scope=\"row\"><b>Id: </b></th>\n            <td style=\"padding-left: 4px;\">MINSAEsquemaVacunacion</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Url: </b></th>\n            <td style=\"padding-left: 4px;\"><a href=\"PlanDefinition-MINSAEsquemaVacunacion.html\">Esquema Nacional de Vacunacion - MINSA Peru</a></td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Version: </b></th>\n            <td style=\"padding-left: 4px;\">1.0.0</td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Title: </b></th>\n            <td style=\"padding-left: 4px;\">Esquema Nacional de Vacunacion - MINSA Peru</td>\n        </tr>\n        \n\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Type: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                    \n                        \n                        <p style=\"margin-bottom: 5px;\">\n                            <b>system: </b> <span><a href=\"http://terminology.hl7.org/7.1.0/CodeSystem-plan-definition-type.html\">http://terminology.hl7.org/CodeSystem/plan-definition-type</a></span>\n                        </p>\n                        \n                        \n                        <p style=\"margin-bottom: 5px;\">\n                            <b>code: </b> <span>eca-rule</span>\n                        </p>\n                        \n                        \n                    \n                \n                \n            </td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Date: </b></th>\n            <td style=\"padding-left: 4px;\">2026-03-16 12:33:41-0400</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Publisher: </b></th>\n            <td style=\"padding-left: 4px;\">MINSA - Ministerio de Salud del Perú</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Description: </b></th>\n            <td style=\"padding-left: 4px;\"><div><p>Esquema Nacional de Vacunacion del Peru para ninos desde el nacimiento hasta los 13 anos.</p>\n</div></td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Knowledge Capability: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                computable \n            </td>\n        </tr>\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Jurisdiction: </b></th>\n            <td style=\"padding-left: 4px;\">PE</td>\n        </tr>\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Related Artifacts: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                \n                <p><b>References</b></p>\n                <ul>\n                    \n                    <li><div><p>NTS N 196-MINSA/DGIESP-2022: Norma Tecnica de Salud que establece el Esquema Nacional de Vacunacion</p>\n</div><br/><a href=\"null\"/></li>\n                    \n                </ul>\n                \n                \n                \n                \n                \n                \n            </td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Actions: </b></th>\n            <td style=\"padding-left: 4px;\">\n                <table class=\"grid-dict\">\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion BCG:</b> Administrar vacuna BCG al recien nacido.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente es recien nacido y no tiene registro de vacunacion BCG\n                            \n                            <i>(Paciente necesita vacuna BCG)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSABCGVacunacion.html\">MINSA - Vacunacion BCG</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion Hepatitis B - Dosis de nacimiento:</b> Administrar vacuna contra Hepatitis B al recien nacido dentro de las primeras 24 horas de vida.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente es recien nacido y no tiene registro de dosis de nacimiento de Hepatitis B\n                            \n                            <i>(Paciente necesita dosis de nacimiento de Hepatitis B)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion Pentavalente (DPT-HepB-Hib):</b> Administrar vacuna Pentavalente a los 2, 4 y 6 meses de edad.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita dosis de vacuna Pentavalente\n                            \n                            <i>(Paciente necesita vacuna Pentavalente)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSAPentavalenteVacunacion.html\">MINSA - Vacunacion Pentavalente (DPT-HepB-Hib)</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion contra Poliomielitis (IPV/APO):</b> Administrar vacunas contra Poliomielitis: IPV a los 2 y 4 meses, APO a los 6 y 18 meses, refuerzo APO a los 4 anos.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita dosis de vacuna contra Poliomielitis\n                            \n                            <i>(Paciente necesita vacuna Polio)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSAPolioVacunacion.html\">MINSA - Vacunacion contra Poliomielitis (IPV/APO)</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion contra Rotavirus:</b> Administrar vacuna contra Rotavirus a los 2 y 4 meses de edad.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita dosis de vacuna contra Rotavirus\n                            \n                            <i>(Paciente necesita vacuna Rotavirus)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSARotavirusVacunacion.html\">MINSA - Vacunacion contra Rotavirus</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion contra Neumococo:</b> Administrar vacuna antineumococica conjugada a los 2 y 4 meses, con refuerzo a los 12 meses de edad.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita dosis de vacuna contra Neumococo\n                            \n                            <i>(Paciente necesita vacuna Neumococo)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSANeumococoVacunacion.html\">MINSA - Vacunacion contra Neumococo (PCV)</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion contra Influenza:</b> Administrar vacuna contra Influenza: primera dosis a los 7 meses, segunda dosis a los 8 meses, luego dosis anual hasta los 5 anos.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita dosis de vacuna contra Influenza\n                            \n                            <i>(Paciente necesita vacuna Influenza)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion SPR (Sarampion-Paperas-Rubeola):</b> Administrar vacuna SPR a los 12 meses con refuerzo a los 18 meses de edad.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita dosis de vacuna SPR\n                            \n                            <i>(Paciente necesita vacuna SPR)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSASPRVacunacion.html\">MINSA - Vacunacion SPR (Sarampion-Paperas-Rubeola)</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion Antiamarilica (Fiebre Amarilla):</b> Administrar vacuna contra Fiebre Amarilla a los 15 meses de edad.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita vacuna contra Fiebre Amarilla\n                            \n                            <i>(Paciente necesita vacuna Antiamarilica)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion DPT - Refuerzos:</b> Administrar refuerzos de DPT a los 18 meses y 4 anos de edad.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            El paciente necesita refuerzo de DPT\n                            \n                            <i>(Paciente necesita refuerzo DPT)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td>\n                            \n                            <b> Vacunacion contra VPH (Virus del Papiloma Humano):</b> Administrar vacuna contra VPH a ninas de 9 a 13 anos, esquema de 2 dosis con intervalo de 6 meses.\n                            \n                            <br/>\n                            \n                            \n                            <b>If:</b>\n                            \n                            <i>Applicability:</i>\n                            \n                            La paciente es nina de 9 a 13 anos y necesita vacuna VPH\n                            \n                            <i>(Paciente necesita vacuna VPH)</i>\n                            <br/>\n                            \n                            \n                            \n                            \n                            <b>Then:</b> <i>Definition:</i> <a href=\"PlanDefinition-MINSAHPVVacunacion.html\">MINSA - Vacunacion contra VPH (Virus del Papiloma Humano)</a><br/>\n                            \n                            \n                            \n                        </td>\n                    </tr>\n                    \n                </table>\n            </td>\n        </tr>\n        \n    </table>\n</div>\n</div>"
  },
