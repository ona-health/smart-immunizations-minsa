  fhir:description [ fhir:v "Logica de decision para la vacunacion antineumococica conjugada segun el Esquema Nacional de\nVacunacion del Peru. Esquema 2+1: dos dosis primarias a los 2 y 4 meses de edad, con una\ndosis de refuerzo a los 12 meses."] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [
         fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ;
         fhir:l <urn:iso:std:iso:3166>
       ] ;
       fhir:code [ fhir:v "PE" ] ;
       fhir:display [ fhir:v "Peru" ]
     ] )
  ] ) ; # 
  fhir:relatedArtifact ( [
     fhir:type [ fhir:v "citation" ] ;
     fhir:citation [ fhir:v "NTS N 196-MINSA/DGIESP-2022: Norma Tecnica de Salud que establece el Esquema Nacional de Vacunacion" ]
  ] [
     fhir:type [ fhir:v "depends-on" ] ;
     fhir:display [ fhir:v "WHO SMART Guidelines - Pneumococcal 2 Doses with Booster Decision Table" ] ;
     fhir:resource [
       fhir:v "http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTPneumococcal2DosesWithBoosterDose"^^xsd:anyURI ;
       fhir:l <http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTPneumococcal2DosesWithBoosterDose>
     ]
  ] ) ; # 
  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "La vacuna antineumococica conjugada protege contra la enfermedad\n      invasiva por Streptococcus pneumoniae (meningitis, neumonia, sepsis). Peru utiliza\n      el esquema 2+1 recomendado por la OMS: 2 dosis primarias con 1 dosis de refuerzo."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 1ra dosis de Neumococo" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 2 meses cumple las condiciones para recibir la primera\n    dosis de vacuna antineumococica conjugada segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 2 meses o mas y no ha recibido la 1ra dosis de Neumococo" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 1ra dosis de Neumococo" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Segunda dosis primaria de la vacuna antineumococica conjugada a los\n      4 meses de edad. Intervalo minimo de 8 semanas desde la primera dosis."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 2da dosis de Neumococo" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 4 meses cumple las condiciones para recibir la segunda\n    dosis de vacuna antineumococica conjugada segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 4 meses o mas, ha recibido la 1ra dosis y no ha recibido la 2da dosis de Neumococo" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 2da dosis de Neumococo" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Dosis de refuerzo de la vacuna antineumococica conjugada a los 12 meses\n      de edad. Esta dosis es esencial para mantener la proteccion a largo plazo. Los lactantes\n      con VIH y prematuros pueden beneficiarse especialmente de esta dosis de refuerzo."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la dosis de refuerzo de Neumococo" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 12 meses cumple las condiciones para recibir la dosis\n    de refuerzo de vacuna antineumococica conjugada segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 12 meses o mas, ha recibido 2 dosis primarias y no ha recibido el refuerzo de Neumococo" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita refuerzo de Neumococo" ]
       ]
     ] ) ;
