       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "La vacuna BCG protege contra las formas graves de tuberculosis\n      (meningitis tuberculosa y tuberculosis miliar). Se administra en dosis unica al recien\n      nacido. En recien nacidos de madres con VIH, se debe evaluar el estado clinico antes\n      de la vacunacion."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el recien nacido necesita vacunacion BCG" ] ;
     fhir:description [ fhir:v "Evaluar si el recien nacido cumple las condiciones para recibir la vacuna BCG\n    segun el protocolo nacional de inmunizaciones." ] ;
