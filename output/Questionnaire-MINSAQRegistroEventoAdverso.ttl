       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "anafilaxia" ] ;
         fhir:display [ fhir:v "Anafilaxia" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "fiebre" ] ;
         fhir:display [ fhir:v "Fiebre" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "otro" ] ;
         fhir:display [ fhir:v "Otro" ]
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "otro-tipo-manifestacion" ] ;
     fhir:text [ fhir:v "Especifique otro tipo de manifestación" ] ;
     fhir:type [ fhir:v "string" ] ;
     fhir:enableWhen ( [
       fhir:question [ fhir:v "tipo-manifestacion" ] ;
       fhir:operator [ fhir:v "=" ] ;
       fhir:answer [
         a fhir:Coding ;
         fhir:code [ fhir:v "otro" ]
       ]
     ] ) ;
     fhir:required [ fhir:v false ]
  ] [
     fhir:linkId [ fhir:v "severidad" ] ;
     fhir:text [ fhir:v "Severidad de la reacción" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v false ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "no-grave" ] ;
         fhir:display [ fhir:v "No grave" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "muerte" ] ;
         fhir:display [ fhir:v "Muerte" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "riesgo-vital" ] ;
         fhir:display [ fhir:v "Riesgo vital" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "discapacidad" ] ;
         fhir:display [ fhir:v "Discapacidad" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "hospitalizacion" ] ;
         fhir:display [ fhir:v "Hospitalización" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "anomalia-congenita" ] ;
         fhir:display [ fhir:v "Anomalía congénita" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "otro-evento-medico-importante" ] ;
         fhir:display [ fhir:v "Otro evento médico importante (especificar)" ]
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "especificar-otro-evento" ] ;
     fhir:text [ fhir:v "Especifique otro evento médico importante" ] ;
     fhir:type [ fhir:v "string" ] ;
     fhir:enableWhen ( [
       fhir:question [ fhir:v "severidad" ] ;
       fhir:operator [ fhir:v "=" ] ;
       fhir:answer [
         a fhir:Coding ;
         fhir:code [ fhir:v "otro-evento-medico-importante" ]
       ]
     ] ) ;
     fhir:required [ fhir:v false ]
  ] [
     fhir:linkId [ fhir:v "resultado" ] ;
     fhir:text [ fhir:v "Resultado de la reacción" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:enableWhen ( [
       fhir:question [ fhir:v "severidad" ] ;
       fhir:operator [ fhir:v "!=" ] ;
       fhir:answer [
         a fhir:Coding ;
         fhir:code [ fhir:v "muerte" ]
       ]
     ] ) ;
     fhir:required [ fhir:v false ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "fallecido" ] ;
         fhir:display [ fhir:v "Fallecido" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "recuperado" ] ;
         fhir:display [ fhir:v "Recuperado" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "recuperado-con-secuelas" ] ;
         fhir:display [ fhir:v "Recuperado con secuelas" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "en-recuperacion" ] ;
         fhir:display [ fhir:v "En recuperación" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "no-recuperado" ] ;
         fhir:display [ fhir:v "No recuperado" ]
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "fecha-fallecimiento" ] ;
     fhir:text [ fhir:v "Fecha de fallecimiento" ] ;
     fhir:type [ fhir:v "date" ] ;
     fhir:enableWhen ( [
       fhir:question [ fhir:v "severidad" ] ;
       fhir:operator [ fhir:v "=" ] ;
       fhir:answer [
         a fhir:Coding ;
         fhir:code [ fhir:v "muerte" ]
       ]
     ] [
       fhir:question [ fhir:v "resultado" ] ;
       fhir:operator [ fhir:v "=" ] ;
       fhir:answer [
         a fhir:Coding ;
         fhir:code [ fhir:v "fallecido" ]
       ]
     ] ) ;
     fhir:enableBehavior [ fhir:v "any" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl>
       ] ;
       fhir:value [
         a fhir:CodeableConcept ;
         fhir:coding ( [
           fhir:system [
             fhir:v "http://hl7.org/fhir/questionnaire-item-control"^^xsd:anyURI ;
             fhir:l <http://hl7.org/fhir/questionnaire-item-control>
           ] ;
           fhir:code [ fhir:v "drop-down" ]
         ] )
       ]
     ] ) ;
     fhir:linkId [ fhir:v "fue-referido" ] ;
     fhir:text [ fhir:v "¿Fue referido el paciente?" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "si" ] ;
         fhir:display [ fhir:v "Sí" ]
       ]
     ] [
       fhir:value [
         a fhir:Coding ;
         fhir:code [ fhir:v "no" ] ;
         fhir:display [ fhir:v "No" ]
       ]
     ] )
  ] ) . # 

