  <action>
    <extension url="http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale">
      <valueMarkdown value="La vacuna SPR (triple virica) protege contra sarampion, paperas y&#xA;      rubeola. La primera dosis se administra a los 12 meses de edad, cuando los anticuerpos&#xA;      maternos han disminuido suficientemente para permitir una respuesta inmune adecuada."/>
    </extension>
    <title value="Determinar si el nino necesita la 1ra dosis de SPR"/>
    <description value="Evaluar si el nino de 12 meses cumple las condiciones para recibir la primera&#xA;    dosis de vacuna SPR segun el protocolo nacional de inmunizaciones."/>
    <condition>
      <kind value="applicability"/>
      <expression>
        <description value="El paciente tiene 12 meses o mas y no ha recibido la 1ra dosis de SPR"/>
        <language value="text/cql-identifier"/>
        <expression value="Paciente necesita 1ra dosis de SPR"/>
      </expression>
    </condition>
    <dynamicValue>
      <path value="status"/>
      <expression>
        <language value="text/cql-expression"/>
        <expression value="'draft'"/>
      </expression>
    </dynamicValue>
    <dynamicValue>
      <path value="intent"/>
      <expression>
        <language value="text/cql-expression"/>
        <expression value="'proposal'"/>
      </expression>
    </dynamicValue>
  </action>
  <action>
    <extension url="http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale">
      <valueMarkdown value="La dosis de refuerzo de SPR a los 18 meses asegura la proteccion a&#xA;      largo plazo. Aproximadamente el 5% de los ninos no responden a la primera dosis,&#xA;      por lo que la segunda dosis garantiza la inmunidad de la poblacion."/>
    </extension>
    <title value="Determinar si el nino necesita la dosis de refuerzo de SPR"/>
    <description value="Evaluar si el nino de 18 meses cumple las condiciones para recibir la dosis&#xA;    de refuerzo de vacuna SPR segun el protocolo nacional de inmunizaciones."/>
    <condition>
      <kind value="applicability"/>
      <expression>
        <description value="El paciente tiene 18 meses o mas, ha recibido la 1ra dosis y no ha recibido el refuerzo de SPR"/>
        <language value="text/cql-identifier"/>
        <expression value="Paciente necesita refuerzo de SPR"/>
      </expression>
    </condition>
    <dynamicValue>
