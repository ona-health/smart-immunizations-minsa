  fhir:description [ fhir:v "Logica de decision para la vacunacion contra el Virus del Papiloma Humano (VPH) segun el\nEsquema Nacional de Vacunacion del Peru. Se administran 2 dosis a ninas de 9 a 13 anos\nde edad, con un intervalo de 6 meses entre dosis."] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [
         fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ;
         fhir:l <urn:iso:std:iso:3166>
       ] ;
       fhir:code [ fhir:v "PE" ] ;
       fhir:display [ fhir:v "Peru" ]
     ] )
  ] ) ; # 
  fhir:relatedArtifact ( [
     fhir:type [ fhir:v "citation" ] ;
     fhir:citation [ fhir:v "NTS N 196-MINSA/DGIESP-2022: Norma Tecnica de Salud que establece el Esquema Nacional de Vacunacion" ]
  ] [
     fhir:type [ fhir:v "depends-on" ] ;
     fhir:display [ fhir:v "WHO SMART Guidelines - HPV 2 Doses Decision Table" ] ;
     fhir:resource [
       fhir:v "http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTHPV2Doses"^^xsd:anyURI ;
       fhir:l <http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTHPV2Doses>
     ]
  ] ) ; # 
  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "La vacuna contra el VPH previene la infeccion por los tipos de VPH\n      que causan cancer de cuello uterino. En Peru se aplica a ninas de 9 a 13 anos con un\n      esquema de 2 dosis. La vacunacion antes del inicio de la actividad sexual proporciona\n      la maxima proteccion."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si la paciente necesita la 1ra dosis de VPH" ] ;
     fhir:description [ fhir:v "Evaluar si la paciente (sexo femenino, 9-13 anos) cumple las condiciones\n    para recibir la primera dosis de vacuna contra VPH segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "La paciente es de sexo femenino, tiene entre 9 y 13 anos, y no ha recibido la 1ra dosis de VPH" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 1ra dosis de VPH" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Segunda dosis de VPH con un intervalo minimo de 6 meses desde la\n      primera dosis. Con 2 dosis se logra una respuesta inmune robusta y duradera en\n      la poblacion objetivo de 9 a 13 anos."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si la paciente necesita la 2da dosis de VPH" ] ;
     fhir:description [ fhir:v "Evaluar si la paciente cumple las condiciones para recibir la segunda dosis\n    de vacuna contra VPH, con al menos 6 meses desde la primera dosis." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "La paciente ha recibido la 1ra dosis de VPH, han pasado al menos 6 meses, y no ha recibido la 2da dosis" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 2da dosis de VPH" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
