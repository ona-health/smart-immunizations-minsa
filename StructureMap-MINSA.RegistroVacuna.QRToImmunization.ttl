  fhir:group ( [
     fhir:name [ fhir:v "RegistroVacuna" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "QResp" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "BundleStatic" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "id" ] ;
         fhir:transform [ fhir:v "uuid" ]
       ] [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "type" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "collection"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CreateEncounter" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:variable [ fhir:v "encounter" ] ;
         fhir:transform [ fhir:v "create" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "Encounter"
           ]
         ] )
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ExtractEncounter" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "ExtractEncounter" ] ;
           fhir:variable ( [ fhir:v "src" ] [ fhir:v "encounter" ] )
         ] )
       ] [
         fhir:name [ fhir:v "VaccineGiven" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ] ;
           fhir:element [ fhir:v "item" ] ;
           fhir:variable [ fhir:v "item" ] ;
           fhir:condition [ fhir:v "((linkId = 'vaccine-administered') and (answer.value.code = 'yes'))" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ImmunizationEntry" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "src" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "bundle" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "entry" ] ;
             fhir:variable [ fhir:v "entry" ]
           ] [
             fhir:context [ fhir:v "entry" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "resource" ] ;
             fhir:variable [ fhir:v "immunization" ] ;
             fhir:transform [ fhir:v "create" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "Immunization"
               ]
             ] )
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "ExtractImmunization" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "src" ]
             ] ) ;
             fhir:dependent ( [
               fhir:name [ fhir:v "ExtractImmunization" ] ;
               fhir:variable ( [ fhir:v "src" ] [ fhir:v "encounter" ] [ fhir:v "immunization" ] )
             ] )
           ] [
             fhir:name [ fhir:v "ExtractTask" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "src" ]
             ] ) ;
             fhir:dependent ( [
               fhir:name [ fhir:v "ExtractTaskCompleted" ] ;
               fhir:variable ( [ fhir:v "src" ] [ fhir:v "encounter" ] [ fhir:v "immunization" ] [ fhir:v "bundle" ] )
             ] )
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "VaccineNotGiven" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ] ;
           fhir:element [ fhir:v "item" ] ;
           fhir:variable [ fhir:v "item" ] ;
           fhir:condition [ fhir:v "((linkId = 'vaccine-administered') and (answer.value.code = 'no'))" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractTaskFailed" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "src" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "ExtractTaskFailed" ] ;
             fhir:variable ( [ fhir:v "src" ] [ fhir:v "bundle" ] )
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "EncounterEntry" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "bundle" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "entry" ] ;
           fhir:variable [ fhir:v "entry" ]
         ] [
           fhir:context [ fhir:v "entry" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "encounter"
             ]
           ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "ExtractEncounter" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Extrae el recurso Encounter para la visita de vacunacion" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "QResp" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "encounter" ] ;
       fhir:type [ fhir:v "Encounter" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EncounterStatic" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "encounter" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "id" ] ;
         fhir:transform [ fhir:v "uuid" ]
       ] [
         fhir:context [ fhir:v "encounter" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "status" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "finished"
           ]
         ] )
       ] [
         fhir:context [ fhir:v "encounter" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "class" ] ;
         fhir:transform [ fhir:v "c" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "http://terminology.hl7.org/CodeSystem/v3-ActCode"
           ]
         ] [
           fhir:value [
             a fhir:String ;
             fhir:v "AMB"
           ]
         ] [
           fhir:value [
             a fhir:String ;
             fhir:v "ambulatory"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EncounterSubject" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "subject" ] ;
         fhir:variable [ fhir:v "subject" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "encounter" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "subject" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "subject"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EncounterType" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "encounter" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "type" ] ;
         fhir:variable [ fhir:v "cc" ] ;
         fhir:transform [ fhir:v "create" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "CodeableConcept"
           ]
         ] )
