  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "La vacuna Pentavalente combina la proteccion contra difteria, tetanos,\n      tos ferina, hepatitis B y Haemophilus influenzae tipo b. Se inicia a los 2 meses de edad\n      como parte del esquema primario de vacunacion infantil."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 1ra dosis de Pentavalente" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 2 meses cumple las condiciones para recibir la primera\n    dosis de vacuna Pentavalente segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 2 meses o mas y no ha recibido la 1ra dosis de Pentavalente" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 1ra dosis de Pentavalente" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'draft'" ]
       ]
     ] [
       fhir:path [ fhir:v "intent" ] ;
       fhir:expression [
         fhir:language [ fhir:v "text/cql-expression" ] ;
         fhir:expression [ fhir:v "'proposal'" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Segunda dosis del esquema primario de Pentavalente. Se administra a los\n      4 meses de edad, con un intervalo minimo de 8 semanas desde la primera dosis."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 2da dosis de Pentavalente" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 4 meses cumple las condiciones para recibir la segunda\n    dosis de vacuna Pentavalente segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 4 meses o mas, ha recibido la 1ra dosis y no ha recibido la 2da dosis de Pentavalente" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 2da dosis de Pentavalente" ]
       ]
     ] ) ;
     fhir:dynamicValue ( [
       fhir:path [ fhir:v "status" ] ;
