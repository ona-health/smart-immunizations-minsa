     fhir:resource [
       fhir:v "http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTDTPOnTimeStart"^^xsd:anyURI ;
       fhir:l <http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTDTPOnTimeStart>
     ]
