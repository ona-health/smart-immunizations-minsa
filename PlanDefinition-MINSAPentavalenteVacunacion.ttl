         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Tercera dosis del esquema primario de Pentavalente. Se administra a los\n      6 meses de edad, completando la serie primaria. El intervalo minimo desde la segunda\n      dosis es de 8 semanas."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determinar si el nino necesita la 3ra dosis de Pentavalente" ] ;
     fhir:description [ fhir:v "Evaluar si el nino de 6 meses cumple las condiciones para recibir la tercera\n    dosis de vacuna Pentavalente segun el protocolo nacional." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "El paciente tiene 6 meses o mas, ha recibido la 2da dosis y no ha recibido la 3ra dosis de Pentavalente" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Paciente necesita 3ra dosis de Pentavalente" ]
       ]
     ] ) ;
